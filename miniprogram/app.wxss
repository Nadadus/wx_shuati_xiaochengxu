/** app.wxss **/

page {
  background: #F6F6F6;
  color: #1f2328;
  font-size: 30rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.container {
  width: 100%;
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 18rpx;
  color: #1f2328;
}

.sub-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 14rpx;
  color: #1f2328;
}

.muted {
  color: #80868f;
  font-size: 26rpx;
  line-height: 1.6;
}

button {
  background: initial;
}

button:focus {
  outline: 0;
}

button::after {
  border: none;
}

.btn {
  height: 82rpx;
  line-height: 82rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
}

.primary-btn {
  background: #2f7cf6;
  color: #ffffff;
}

.gray-btn {
  background: #f1f3f5;
  color: #333333;
}