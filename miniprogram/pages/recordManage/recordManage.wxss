.picker-row {
  height: 86rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 0 24rpx;
  margin-top: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #1f2328;
}

.picker-value {
  color: #2f7cf6;
  font-weight: 600;
}

.block-desc {
  margin-bottom: 22rpx;
}

.manage-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  margin-top: 18rpx;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.blue-btn {
  background: #eaf2ff;
  color: #2f7cf6;
}

.orange-btn {
  background: #fff7ed;
  color: #b45309;
}

.purple-btn {
  background: #f3e8ff;
  color: #7e22ce;
}

.light-red-btn {
  background: #fff0f0;
  color: #d93025;
}