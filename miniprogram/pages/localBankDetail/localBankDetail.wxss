.empty-card {
  text-align: center;
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.bank-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #eaf2ff;
  color: #2f7cf6;
  flex-shrink: 0;
}

.description-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
}

.input-label {
  font-size: 28rpx;
  color: #1f2328;
  font-weight: 600;
  margin-top: 18rpx;
  margin-bottom: 12rpx;
}

.rename-input {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2328;
}

.rename-btn {
  width: 100%;
  height: 76rpx;
  border-radius: 18rpx;
  background: #eaf2ff;
  color: #2f7cf6;
  font-size: 28rpx;
  font-weight: 600;
  padding: 0;
  margin-top: 22rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.stat-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  background: #f7f8fa;
  border-radius: 18rpx;
  padding: 22rpx 8rpx;
  text-align: center;
}

.stat-number {
  font-size: 38rpx;
  color: #1f2328;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #80868f;
}

.record-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

.record-row:last-child {
  border-bottom: none;
}

.record-label {
  font-size: 27rpx;
  color: #5f6670;
  line-height: 1.5;
  flex: 1;
}

.record-value {
  font-size: 27rpx;
  color: #1f2328;
  font-weight: 600;
  text-align: right;
  max-width: 420rpx;
  word-break: break-all;
}

.danger-preview-card {
  border: 2rpx solid #ffe0e0;
}

.danger-desc {
  background: #fff0f0;
  color: #d93025;
  border-radius: 18rpx;
  padding: 20rpx 22rpx;
  font-size: 26rpx;
  line-height: 1.7;
  margin-top: 18rpx;
}

.delete-impact-grid {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.delete-impact-item {
  flex: 1;
  background: #fff7f7;
  border-radius: 16rpx;
  padding: 18rpx 6rpx;
  text-align: center;
}

.impact-num {
  font-size: 30rpx;
  color: #d93025;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.impact-label {
  font-size: 24rpx;
  color: #9b1c1c;
}

.subject-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

.subject-row:last-child {
  border-bottom: none;
}

.subject-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 6rpx;
}

.subject-order {
  font-size: 26rpx;
  color: #80868f;
  flex-shrink: 0;
}

.chapter-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

.chapter-row:last-child {
  border-bottom: none;
}

.chapter-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 6rpx;
}

.chapter-count {
  font-size: 26rpx;
  color: #2f7cf6;
  font-weight: 700;
  flex-shrink: 0;
}

.action-card {
  padding-bottom: 34rpx;
}

.copy-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #eaf2ff;
  color: #2f7cf6;
  padding: 0;
  margin-bottom: 20rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.delete-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff0f0;
  color: #d93025;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}