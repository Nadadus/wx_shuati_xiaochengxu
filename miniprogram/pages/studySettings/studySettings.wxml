<view class="container">
  <view class="card">
    <view class="title">学习设置</view>
    <view class="muted">设置考试日期后，首页会自动计算剩余天数。</view>
  </view>

  <view class="card">
    <view class="sub-title">考试日期</view>

    <picker mode="date" value="{{examDate}}" bindchange="onExamDateChange">
      <view class="date-picker">
        {{examDate}} ▼
      </view>
    </picker>

    <button class="btn primary-btn" bindtap="saveSettings">保存设置</button>
  </view>
</view>