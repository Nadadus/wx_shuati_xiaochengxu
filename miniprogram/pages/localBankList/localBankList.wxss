.export-entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.function-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 8rpx;
}

.arrow {
  font-size: 54rpx;
  color: #b5bbc4;
}

.empty-card {
  text-align: center;
}

.local-bank-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.local-bank-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.local-bank-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 8rpx;
}

.local-bank-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  background: #eaf2ff;
  color: #2f7cf6;
  flex-shrink: 0;
}

.local-bank-info {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.local-info-item {
  flex: 1;
  background: #f7f8fa;
  border-radius: 18rpx;
  padding: 18rpx 8rpx;
  text-align: center;
}

.local-info-num {
  font-size: 30rpx;
  color: #1f2328;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.local-info-label {
  font-size: 24rpx;
  color: #80868f;
}

.local-bank-actions {
  display: flex;
  gap: 14rpx;
}

.local-action-btn {
  flex: 1;
  height: 70rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.copy-bank-btn {
  background: #eaf2ff;
  color: #2f7cf6;
}

.delete-bank-btn {
  background: #fff0f0;
  color: #d93025;
}