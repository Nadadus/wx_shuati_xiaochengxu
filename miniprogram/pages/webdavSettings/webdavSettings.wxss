.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.setting-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 8rpx;
}

.input-label {
  font-size: 28rpx;
  color: #1f2328;
  font-weight: 600;
  margin-top: 26rpx;
  margin-bottom: 12rpx;
}

.input-box {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 0 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2328;
}

.password-row {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 0 18rpx 0 24rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
}

.password-input {
  flex: 1;
  height: 78rpx;
  font-size: 28rpx;
  color: #1f2328;
}

.password-toggle {
  width: 92rpx;
  text-align: center;
  font-size: 26rpx;
  color: #2f7cf6;
  font-weight: 600;
  flex-shrink: 0;
}

.readonly-box {
  width: 100%;
  min-height: 78rpx;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  color: #1f2328;
  font-weight: 600;
  word-break: break-all;
}

.status-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid #f0f1f3;
}

.status-row:last-child {
  border-bottom: none;
}

.status-label {
  font-size: 27rpx;
  color: #5f6670;
  flex-shrink: 0;
}

.status-value {
  font-size: 27rpx;
  color: #1f2328;
  font-weight: 600;
  text-align: right;
  word-break: break-all;
}

.restore-row {
  margin-top: 24rpx;
}

.test-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #eaf2ff;
  color: #2f7cf6;
  padding: 0;
  margin-top: 28rpx;
  margin-bottom: 20rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.backup-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #2f7cf6;
  color: #ffffff;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.select-file-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #eef0f3;
  color: #333333;
  padding: 0;
  margin-top: 20rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.selected-file-box {
  width: 100%;
  border-radius: 18rpx;
  background: #f7f8fa;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  margin-top: 18rpx;
}

.selected-file-label {
  font-size: 24rpx;
  color: #80868f;
  margin-bottom: 8rpx;
}

.selected-file-name {
  font-size: 28rpx;
  color: #1f2328;
  font-weight: 600;
  word-break: break-all;
}

.restore-tip {
  margin-top: 14rpx;
  font-size: 25rpx;
  color: #80868f;
  line-height: 1.6;
}

.restore-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff7ed;
  color: #b45309;
  padding: 0;
  margin-top: 28rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.save-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #2f7cf6;
  color: #ffffff;
  padding: 0;
  margin-bottom: 20rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.clear-btn {
  width: 100%;
  height: 78rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff0f0;
  color: #d93025;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.status-text {
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
  word-break: break-all;
}

.backup-picker-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  z-index: 999;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.backup-picker-panel {
  width: 100%;
  max-height: 78vh;
  background: #ffffff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 28rpx;
  box-sizing: border-box;
}

.backup-picker-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 22rpx;
}

.backup-picker-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 8rpx;
}

.backup-picker-subtitle {
  font-size: 25rpx;
  color: #80868f;
  word-break: break-all;
}

.backup-picker-close {
  font-size: 26rpx;
  color: #80868f;
  flex-shrink: 0;
}

.backup-picker-list {
  max-height: 50vh;
  background: #f7f8fa;
  border-radius: 22rpx;
  padding: 10rpx 18rpx;
  box-sizing: border-box;
}

.backup-file-empty {
  font-size: 26rpx;
  color: #80868f;
  text-align: center;
  padding: 36rpx 0;
}

.backup-file-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #e9ebef;
}

.backup-file-item:last-child {
  border-bottom: none;
}

.backup-file-name {
  font-size: 27rpx;
  font-weight: 700;
  color: #1f2328;
  word-break: break-all;
}

.backup-file-meta {
  font-size: 24rpx;
  color: #80868f;
  margin-top: 6rpx;
}

.backup-file-select {
  font-size: 26rpx;
  color: #2f7cf6;
  font-weight: 600;
  flex-shrink: 0;
}

.use-last-backup-btn {
  width: 100%;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #eaf2ff;
  color: #2f7cf6;
  padding: 0;
  margin-top: 22rpx;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}