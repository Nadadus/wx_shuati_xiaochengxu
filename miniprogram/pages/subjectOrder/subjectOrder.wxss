.empty-card {
  text-align: center;
}

.subject-card {
  background: #ffffff;
  border-radius: 28rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.subject-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.subject-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2328;
  margin-bottom: 8rpx;
}

.status-tag {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.status-enabled {
  background: #e9f8ef;
  color: #18a058;
}

.status-disabled {
  background: #eef0f3;
  color: #80868f;
}

.subject-actions {
  display: flex;
  gap: 14rpx;
}

.action-btn {
  flex: 1;
  height: 68rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 600;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.gray-action {
  background: #eef0f3;
  color: #333333;
}

.enable-action {
  background: #eaf2ff;
  color: #2f7cf6;
}

.disable-action {
  background: #fff7ed;
  color: #b45309;
}

.reset-btn {
  width: 100%;
  height: 76rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #fff0f0;
  color: #d93025;
  padding: 0;

  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}